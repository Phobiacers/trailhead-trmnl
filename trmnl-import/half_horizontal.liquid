<style>
  .trailhead-half-h {
    color: #000;
    display: grid;
    font-family: Inter, Arial, sans-serif;
    gap: 12px;
    grid-template-columns: 0.95fr 1.05fr;
    height: 100%;
  }

  .thh-panel {
    border: 2px solid #000;
    min-height: 0;
    padding: 8px;
  }

  .thh-route {
    background:
      linear-gradient(90deg, #ddd 1px, transparent 1px),
      linear-gradient(#ddd 1px, transparent 1px);
    background-size: 18px 18px;
    height: 138px;
    width: 100%;
  }

  .thh-profile {
    height: 40px;
    margin-top: 6px;
    width: 100%;
  }

  .thh-copy {
    display: flex;
    flex-direction: column;
    gap: 7px;
    min-width: 0;
  }

  .thh-kicker {
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .thh-name {
    font-size: 31px;
    font-weight: 900;
    line-height: 0.95;
  }

  .thh-stats {
    display: grid;
    gap: 6px;
    grid-template-columns: repeat(3, 1fr);
  }

  .thh-stat {
    border-top: 2px solid #000;
    font-size: 12px;
    font-weight: 800;
    padding-top: 5px;
  }

  .thh-stat strong {
    display: block;
    font-size: 18px;
    line-height: 1;
  }

  .thh-obstacle {
    background: #000;
    color: #fff;
    font-size: 14px;
    font-weight: 800;
    line-height: 1.15;
    padding: 7px;
  }
</style>

{% if trail_name == blank and data.trail_name != blank %}
  {% assign trail_name = data.trail_name %}
  {% assign state_label = data.state_label %}
  {% assign trail_region = data.trail_region %}
  {% assign season_label = data.season_label %}
  {% assign difficulty = data.difficulty %}
  {% assign length_mi = data.length_mi %}
  {% assign elevation_gain_ft = data.elevation_gain_ft %}
  {% assign obstacle_name = data.obstacle_name %}
  {% assign obstacle_blurb = data.obstacle_blurb %}
  {% assign obstacle_position_pct = data.obstacle_position_pct %}
  {% assign obstacle_trace_x = data.obstacle_trace_x %}
  {% assign obstacle_trace_y = data.obstacle_trace_y %}
  {% assign route_path = data.route_path %}
  {% assign profile_points = data.profile_points %}
  {% assign message = data.message %}
{% endif %}
{% if trail_name == blank and IDX_0.trail_name != blank %}
  {% assign trail_name = IDX_0.trail_name %}
  {% assign state_label = IDX_0.state_label %}
  {% assign trail_region = IDX_0.trail_region %}
  {% assign season_label = IDX_0.season_label %}
  {% assign difficulty = IDX_0.difficulty %}
  {% assign length_mi = IDX_0.length_mi %}
  {% assign elevation_gain_ft = IDX_0.elevation_gain_ft %}
  {% assign obstacle_name = IDX_0.obstacle_name %}
  {% assign obstacle_blurb = IDX_0.obstacle_blurb %}
  {% assign obstacle_position_pct = IDX_0.obstacle_position_pct %}
  {% assign obstacle_trace_x = IDX_0.obstacle_trace_x %}
  {% assign obstacle_trace_y = IDX_0.obstacle_trace_y %}
  {% assign route_path = IDX_0.route_path %}
  {% assign profile_points = IDX_0.profile_points %}
  {% assign message = IDX_0.message %}
{% endif %}
{% if message == blank %}
  {% assign message = "No Trailhead data found. Check polling URL, save, then force refresh." %}
{% endif %}

{% if trail_name == blank %}
  <div class="layout trailhead-half-h">
    <div class="thh-panel">
      <div class="thh-name">No data</div>
      <div class="thh-obstacle">{{ message }}</div>
    </div>
  </div>
{% else %}
  <div class="layout trailhead-half-h">
    <div class="thh-panel">
      <svg class="thh-route" viewBox="0 0 100 60" preserveAspectRatio="none" aria-label="Simplified trail trace">
        <path d="{{ route_path }}" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" />
        <circle cx="{{ obstacle_trace_x }}" cy="{{ obstacle_trace_y }}" r="3.2" fill="#fff" stroke="#000" stroke-width="2.4" />
      </svg>
      <svg class="thh-profile" viewBox="0 0 100 48" preserveAspectRatio="none" aria-label="Simplified elevation profile">
        <polyline points="{{ profile_points }}" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="3" />
        <line x1="{{ obstacle_position_pct }}" y1="3" x2="{{ obstacle_position_pct }}" y2="45" stroke="#000" stroke-dasharray="2 2" stroke-width="1" />
      </svg>
    </div>
    <div class="thh-copy">
      <div class="thh-kicker">{{ state_label }} / {{ trail_region }} / {{ season_label }}</div>
      <div class="thh-name" data-value-fit="true" data-value-fit-max-height="62">{{ trail_name }}</div>
      <div class="thh-stats">
        <div class="thh-stat"><strong>{{ difficulty }}/10</strong>diff</div>
        <div class="thh-stat"><strong>{{ length_mi }}</strong>mi</div>
        <div class="thh-stat"><strong>{{ elevation_gain_ft }}</strong>ft gain</div>
      </div>
      <div class="thh-obstacle">{{ obstacle_name }}: {{ obstacle_blurb }}</div>
    </div>
  </div>
{% endif %}

<div class="title_bar">
  <span class="title">Trailhead</span>
  <span class="instance">{{ state_label }}</span>
</div>
