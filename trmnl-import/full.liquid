<style>
  .trailhead-full {
    color: #000;
    display: flex;
    flex-direction: column;
    font-family: Inter, Arial, sans-serif;
    gap: 12px;
    height: 100%;
  }

  .th-grid {
    display: grid;
    flex: 1;
    gap: 14px;
    grid-template-columns: 1.1fr 0.9fr;
    min-height: 0;
  }

  .th-panel {
    border: 2px solid #000;
    min-height: 0;
    padding: 10px;
  }

  .th-map {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .th-route-svg {
    background:
      linear-gradient(90deg, #ddd 1px, transparent 1px),
      linear-gradient(#ddd 1px, transparent 1px);
    background-size: 20px 20px;
    border-bottom: 1px solid #000;
    flex: 1;
    min-height: 170px;
    width: 100%;
  }

  .th-profile-svg {
    height: 76px;
    width: 100%;
  }

  .th-info {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .th-kicker {
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .th-name {
    font-size: 46px;
    font-weight: 900;
    line-height: 0.95;
  }

  .th-highlight {
    border-top: 2px solid #000;
    font-size: 18px;
    line-height: 1.18;
    padding-top: 8px;
  }

  .th-stats {
    display: grid;
    gap: 7px;
    grid-template-columns: repeat(3, 1fr);
  }

  .th-stat {
    border: 1px solid #000;
    padding: 7px 6px;
  }

  .th-stat-value {
    display: block;
    font-size: 23px;
    font-weight: 900;
    line-height: 1;
  }

  .th-stat-label {
    display: block;
    font-size: 10px;
    font-weight: 800;
    margin-top: 4px;
    text-transform: uppercase;
  }

  .th-obstacle {
    background: #000;
    color: #fff;
    padding: 10px;
  }

  .th-obstacle-name {
    display: block;
    font-size: 25px;
    font-weight: 900;
    line-height: 1;
  }

  .th-obstacle-copy {
    display: block;
    font-size: 15px;
    line-height: 1.18;
    margin-top: 7px;
  }

  .th-meta {
    display: flex;
    font-size: 13px;
    font-weight: 800;
    justify-content: space-between;
    text-transform: uppercase;
  }
</style>

{% if trail_name == blank and data.trail_name != blank %}
  {% assign trail_name = data.trail_name %}
  {% assign state_label = data.state_label %}
  {% assign trail_region = data.trail_region %}
  {% assign season_label = data.season_label %}
  {% assign difficulty = data.difficulty %}
  {% assign length_mi = data.length_mi %}
  {% assign elevation_gain_ft = data.elevation_gain_ft %}
  {% assign highlight = data.highlight %}
  {% assign obstacle_name = data.obstacle_name %}
  {% assign obstacle_blurb = data.obstacle_blurb %}
  {% assign obstacle_position_pct = data.obstacle_position_pct %}
  {% assign obstacle_trace_x = data.obstacle_trace_x %}
  {% assign obstacle_trace_y = data.obstacle_trace_y %}
  {% assign route_path = data.route_path %}
  {% assign profile_points = data.profile_points %}
  {% assign profile_min_ft = data.profile_min_ft %}
  {% assign profile_max_ft = data.profile_max_ft %}
  {% assign cycle_index_display = data.cycle_index_display %}
  {% assign cycle_eligible_count = data.cycle_eligible_count %}
  {% assign message = data.message %}
{% endif %}
{% if trail_name == blank and IDX_0.trail_name != blank %}
  {% assign trail_name = IDX_0.trail_name %}
  {% assign state_label = IDX_0.state_label %}
  {% assign trail_region = IDX_0.trail_region %}
  {% assign season_label = IDX_0.season_label %}
  {% assign difficulty = IDX_0.difficulty %}
  {% assign length_mi = IDX_0.length_mi %}
  {% assign elevation_gain_ft = IDX_0.elevation_gain_ft %}
  {% assign highlight = IDX_0.highlight %}
  {% assign obstacle_name = IDX_0.obstacle_name %}
  {% assign obstacle_blurb = IDX_0.obstacle_blurb %}
  {% assign obstacle_position_pct = IDX_0.obstacle_position_pct %}
  {% assign obstacle_trace_x = IDX_0.obstacle_trace_x %}
  {% assign obstacle_trace_y = IDX_0.obstacle_trace_y %}
  {% assign route_path = IDX_0.route_path %}
  {% assign profile_points = IDX_0.profile_points %}
  {% assign profile_min_ft = IDX_0.profile_min_ft %}
  {% assign profile_max_ft = IDX_0.profile_max_ft %}
  {% assign cycle_index_display = IDX_0.cycle_index_display %}
  {% assign cycle_eligible_count = IDX_0.cycle_eligible_count %}
  {% assign message = IDX_0.message %}
{% endif %}
{% if message == blank %}
  {% assign message = "No Trailhead data found. Check polling URL, save, then force refresh." %}
{% endif %}

{% if trail_name == blank %}
  <div class="layout trailhead-full">
    <div class="th-panel">
      <div class="th-name">No Trailhead data</div>
      <div class="th-highlight">{{ message }}</div>
    </div>
  </div>
{% else %}
  <div class="layout trailhead-full">
    <div class="th-grid">
      <div class="th-panel th-map">
        <svg class="th-route-svg" viewBox="0 0 100 60" preserveAspectRatio="none" aria-label="Simplified trail trace">
          <path d="{{ route_path }}" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" />
          <circle cx="{{ obstacle_trace_x }}" cy="{{ obstacle_trace_y }}" r="3.2" fill="#fff" stroke="#000" stroke-width="2.4" />
          <line x1="{{ obstacle_trace_x }}" y1="{{ obstacle_trace_y }}" x2="{{ obstacle_trace_x }}" y2="60" stroke="#000" stroke-dasharray="2 2" stroke-width="1" />
        </svg>
        <svg class="th-profile-svg" viewBox="0 0 100 48" preserveAspectRatio="none" aria-label="Simplified elevation profile">
          <polyline points="{{ profile_points }}" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="3" />
          <line x1="0" y1="45" x2="100" y2="45" stroke="#000" stroke-width="1" />
          <line x1="{{ obstacle_position_pct }}" y1="4" x2="{{ obstacle_position_pct }}" y2="45" stroke="#000" stroke-dasharray="2 2" stroke-width="1" />
        </svg>
        <div class="th-meta">
          <span>{{ profile_min_ft }} ft</span>
          <span>{{ obstacle_position_pct }}% route</span>
          <span>{{ profile_max_ft }} ft</span>
        </div>
      </div>

      <div class="th-info">
        <div>
          <div class="th-kicker">{{ state_label }} / {{ trail_region }} / {{ season_label }}</div>
          <div class="th-name" data-value-fit="true" data-value-fit-max-height="96">{{ trail_name }}</div>
        </div>
        <div class="th-stats">
          <div class="th-stat">
            <span class="th-stat-value">{{ difficulty }}/10</span>
            <span class="th-stat-label">Difficulty</span>
          </div>
          <div class="th-stat">
            <span class="th-stat-value">{{ length_mi }}</span>
            <span class="th-stat-label">Miles</span>
          </div>
          <div class="th-stat">
            <span class="th-stat-value">{{ elevation_gain_ft }}</span>
            <span class="th-stat-label">Ft Gain</span>
          </div>
        </div>
        <div class="th-highlight">{{ highlight }}</div>
        <div class="th-obstacle">
          <span class="th-obstacle-name">{{ obstacle_name }}</span>
          <span class="th-obstacle-copy">{{ obstacle_blurb }}</span>
        </div>
      </div>
    </div>
  </div>
{% endif %}

<div class="title_bar">
  <span class="title">Trailhead</span>
  <span class="instance">{{ state_label }} trail {{ cycle_index_display }}/{{ cycle_eligible_count }}</span>
</div>
