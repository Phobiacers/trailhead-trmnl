<style>
  .debug {
    color: #000;
    font-family: Inter, Arial, sans-serif;
    font-size: 20px;
    line-height: 1.3;
    padding: 24px;
  }

  .debug h1 {
    font-size: 34px;
    margin: 0 0 18px;
  }

  .debug-row {
    border-bottom: 1px solid #000;
    padding: 8px 0;
  }

  .debug-label {
    display: inline-block;
    font-weight: 800;
    width: 190px;
  }
</style>

<div class="layout debug">
  <h1>Trailhead Debug</h1>
  <div class="debug-row"><span class="debug-label">root trail_name</span>{{ trail_name }}</div>
  <div class="debug-row"><span class="debug-label">root state_label</span>{{ state_label }}</div>
  <div class="debug-row"><span class="debug-label">data trail_name</span>{{ data.trail_name }}</div>
  <div class="debug-row"><span class="debug-label">data state_label</span>{{ data.state_label }}</div>
  <div class="debug-row"><span class="debug-label">IDX_0 trail_name</span>{{ IDX_0.trail_name }}</div>
  <div class="debug-row"><span class="debug-label">IDX_0 state_label</span>{{ IDX_0.state_label }}</div>
  <div class="debug-row"><span class="debug-label">form state</span>{{ state }}</div>
  <div class="debug-row"><span class="debug-label">form difficulty</span>{{ max_difficulty }}</div>
  <div class="debug-row"><span class="debug-label">form seasonal</span>{{ seasonal_only }}</div>
</div>

<div class="title_bar">
  <span class="title">Trailhead Debug</span>
</div>
